# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in real values
# This file IS committed to Git. The actual .env is NOT.
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub — your Docker Hub username
DOCKERHUB_USERNAME=yourdockerhubusername

# PostgreSQL
POSTGRES_DB=carrentaldb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Spring Boot JWT
JWT_SECRET=replace-with-a-long-random-secret-string

# Spring Boot Mail (Gmail App Password — no spaces)
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Frontend URL (e.g. for verification links)
FRONTEND_URL=http://localhost:4200
